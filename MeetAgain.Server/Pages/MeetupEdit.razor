@page "/meetups/{MeetupId}/edit"
@inject MeetupService MeetupService
@inject FirestoreService FirestoreService
@inject AuthService Auth
@inject NavigationManager Nav

<div class="max-w-4xl mx-auto">
    @if (loading)
    {
        <div class="loading-container">
            <div class="loading-spinner"></div>
            <p style="margin-top: 1rem; color: var(--gray-600);">Loading meetup details…</p>
        </div>
    }
    else if (meetup == null)
    {
        <div class="card">
            <div class="empty-state">
                <div class="empty-state-icon">❌</div>
                <h3 class="empty-state-title">Meetup Not Found</h3>
                <p class="empty-state-description">
                    This meetup doesn’t exist or you don’t have permission to edit it.
                </p>
                <a href="/meetups" class="btn btn-primary">Back to Meetups</a>
            </div>
        </div>
    }
    else
    {
        <div class="card fade-in">
            <div class="meetup-header">
                <div class="meetup-header-content">
                    <a href="/meetups/@MeetupId" class="btn-back">← Back to Details</a>
                    <h1 class="meetup-detail-title">Edit Meetup</h1>
                </div>
            </div>

            <EditForm Model="meetup" OnValidSubmit="SaveChanges">
                <div class="form-group">
                    <label>Title</label>
                    <InputText class="form-input" @bind-Value="meetup.Title" />
                </div>

                <div class="form-group">
                    <label>Description</label>
                    <InputTextArea class="form-input" @bind-Value="meetup.Description" />
                </div>

                <div class="form-group">
                    <label>Date</label>
                    <InputDate class="form-input" @bind-Value="meetup.EventDateTime" />
                </div>

                <div class="form-actions">
                    <button class="btn btn-primary">Save Changes</button>

                    <a href="#"
                       class="btn btn-outline"
                       @onclick="ShowDeleteModal"
                       @onclick:preventDefault
                       style="color: var(--danger); border-color: var(--danger);">
                        🗑️ Delete
                    </a>
                </div>
            </EditForm>
        </div>
    }
</div>

@if (showDeleteConfirm)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <h3 class="modal-title">Delete Meetup?</h3>

            <p class="modal-description">
                Are you sure you want to delete “<strong>@meetup?.Title</strong>”?
                This cannot be undone.
            </p>

            <div class="modal-actions">
                <a href="#"
                   class="btn btn-outline"
                   @onclick="CancelDelete"
                   @onclick:preventDefault>
                    Cancel
                </a>

                <button type="button"
                        class="btn btn-primary"
                        style="background: var(--danger);"
                        disabled="@isDeleting"
                        @onclick="ConfirmDelete"
                        @onclick:preventDefault>
                    @if (isDeleting)
                    {
                        <span class="loading-spinner" style="width:1rem;height:1rem;margin-right:.5rem;"></span>
                        @:Deleting…
                    }
                    else
                    {
                        @:Delete Meetup
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string MeetupId { get; set; } = "";

    private Meetup? meetup;
    private bool loading = true;
    private bool showDeleteConfirm = false;
    private bool isDeleting = false;

    protected override async Task OnInitializedAsync()
    {   
        await Auth.TryRestoreSessionAsync();
        var user = await Auth.GetCurrentUserAsync();
        if (user == null)
        {
            Nav.NavigateTo("/login");
            return;
        }

        try
        {
            meetup = await FirestoreService.GetMeetupByIdAsync(MeetupId);

            if (meetup != null && meetup.CreatorUserId != user.Uid)
                meetup = null;
        }
        catch
        {
            meetup = null;
        }

        loading = false;
    }

    private async Task SaveChanges()
    {
        if (meetup == null) return;

        await MeetupService.UpdateMeetupAsync(meetup);
        Nav.NavigateTo($"/meetups/{MeetupId}");
    }

    private void ShowDeleteModal() => showDeleteConfirm = true;

    private void CancelDelete() => showDeleteConfirm = false;

    private async Task ConfirmDelete()
    {
        if (meetup == null) return;

        isDeleting = true;
        var ok = await MeetupService.DeleteMeetupAsync(meetup.Id);

        if (ok)
        {
            Nav.NavigateTo("/meetups", true);
        }

        isDeleting = false;
    }
}
