@page "/meetups"
@inject MeetupService MeetupService
@inject AuthService Auth
@inject NavigationManager Nav

<div class="max-w-4xl mx-auto">
    <div class="page-header">
        <div>
            <h2 class="page-title">My Meetups</h2>
            <p class="page-subtitle">View and manage all your scheduled meetups</p>
        </div>
        <button type="button" class="btn btn-primary" @onclick="GoToCreateMeetup">
            ➕ New Meetup
        </button>
    </div>

    @if (loading)
    {
        <div class="loading-container">
            <div class="loading-spinner"></div>
            <p style="margin-top: 1rem; color: var(--gray-600);">Loading meetups...</p>
        </div>
    }
    else if (meetups == null || !meetups.Any())
    {
        <div class="card">
            <div class="empty-state">
                <div class="empty-state-icon">📅</div>
                <h3 class="empty-state-title">No Meetups Yet</h3>
                <p class="empty-state-description">
                    Get started by creating your first meetup with friends!
                </p>
                <button type="button" class="btn btn-primary" @onclick="GoToCreateMeetup">
                    Create Your First Meetup
                </button>
            </div>
        </div>
    }
    else
    {
        <!-- Filter Tabs -->
        <div class="filter-tabs">
            <button type="button" class="filter-tab @(activeFilter == "all" ? "active" : "")" 
                    @onclick="@(() => SetFilter("all"))">
                All (@meetups.Count)
            </button>
            <button type="button" class="filter-tab @(activeFilter == "upcoming" ? "active" : "")" 
                    @onclick="@(() => SetFilter("upcoming"))">
                Upcoming (@upcomingMeetups.Count)
            </button>
            <button type="button" class="filter-tab @(activeFilter == "past" ? "active" : "")" 
                    @onclick="@(() => SetFilter("past"))">
                Past (@pastMeetups.Count)
            </button>
        </div>

        <!-- Meetups List -->
        <div class="meetups-container">
            @foreach (var meetup in GetFilteredMeetups())
            {
                <a href="/meetups/@meetup.Id" class="meetup-item @(IsPast(meetup) ? "past" : "")" 
                   style="text-decoration: none; color: inherit; display: flex;">
                    <div class="meetup-item-content">
                        <div class="meetup-item-header">
                            <h3 class="meetup-item-title">@meetup.Title</h3>
                            @if (IsPast(meetup))
                            {
                                <span class="badge badge-gray">Past</span>
                            }
                            else if (IsToday(meetup))
                            {
                                <span class="badge badge-warning">Today</span>
                            }
                            else if (IsSoon(meetup))
                            {
                                <span class="badge badge-primary">Soon</span>
                            }
                        </div>

                        <p class="meetup-item-description">
                            @(meetup.Description.Length > 150 
                                ? meetup.Description.Substring(0, 150) + "..." 
                                : meetup.Description)
                        </p>

                        <div class="meetup-item-footer">
                            <span class="meetup-item-date">
                                📅 @meetup.EventDateTime.ToLocalTime().ToString("MMMM dd, yyyy")
                            </span>
                            <span class="meetup-item-time">
                                🕐 @meetup.EventDateTime.ToLocalTime().ToString("h:mm tt")
                            </span>
                            @if (!IsPast(meetup))
                            {
                                <span class="meetup-item-countdown">
                                    @GetCountdown(meetup)
                                </span>
                            }
                        </div>
                    </div>
                </a>
            }
        </div>
    }
</div>

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 2rem;
    }

    .page-title {
        font-size: 2rem;
        font-weight: 700;
        color: var(--gray-900);
        margin-bottom: 0.25rem;
    }

    .page-subtitle {
        color: var(--gray-600);
        font-size: 1rem;
    }

    .filter-tabs {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
        border-bottom: 2px solid var(--gray-200);
    }

    .filter-tab {
        padding: 0.75rem 1.5rem;
        background: transparent;
        border: none;
        color: var(--gray-600);
        font-weight: 600;
        cursor: pointer;
        border-bottom: 3px solid transparent;
        margin-bottom: -2px;
        transition: all 0.2s ease;
    }

    .filter-tab:hover {
        color: var(--primary);
    }

    .filter-tab.active {
        color: var(--primary);
        border-bottom-color: var(--primary);
    }

    .meetups-container {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .meetup-item {
        background: white;
        border: 2px solid var(--gray-200);
        border-radius: var(--radius-lg);
        padding: 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .meetup-item:hover {
        border-color: var(--primary);
        box-shadow: var(--shadow-md);
        transform: translateY(-2px);
    }

    .meetup-item.past {
        opacity: 0.7;
        background: var(--gray-50);
    }

    .meetup-item-content {
        flex: 1;
    }

    .meetup-item-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
    }

    .meetup-item-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--gray-900);
        margin: 0;
    }

    .badge {
        padding: 0.25rem 0.75rem;
        border-radius: 9999px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .badge-primary {
        background: var(--primary);
        color: white;
    }

    .badge-warning {
        background: var(--warning);
        color: white;
    }

    .badge-gray {
        background: var(--gray-300);
        color: var(--gray-700);
    }

    .meetup-item-description {
        color: var(--gray-600);
        line-height: 1.6;
        margin-bottom: 1rem;
    }

    .meetup-item-footer {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
        font-size: 0.875rem;
        color: var(--gray-600);
    }

    .meetup-item-countdown {
        color: var(--primary);
        font-weight: 600;
    }

    .meetup-item-actions {
        display: flex;
        gap: 0.5rem;
        margin-left: 1rem;
    }

    .btn-icon {
        width: 2.5rem;
        height: 2.5rem;
        border: none;
        background: var(--gray-100);
        border-radius: var(--radius);
        cursor: pointer;
        transition: all 0.2s ease;
        font-size: 1.125rem;
    }

    .btn-icon:hover {
        background: var(--gray-200);
        transform: scale(1.1);
    }

    @@media (max-width: 768px) {
        .page-header {
            flex-direction: column;
            gap: 1rem;
        }

        .meetup-item {
            flex-direction: column;
        }

        .meetup-item-actions {
            margin-left: 0;
            margin-top: 1rem;
        }
    }
</style>

@code {
    private List<MeetupDto>? meetups;
    private List<MeetupDto> upcomingMeetups = new();
    private List<MeetupDto> pastMeetups = new();
    private string activeFilter = "all";
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Console.WriteLine("Meetups: Starting initialization");

            var user = await Auth.GetCurrentUserAsync();
            if (user == null)
            {
                Console.WriteLine("Meetups: No user found, redirecting to login");
                Nav.NavigateTo("/login");
                return;
            }

            Console.WriteLine($"Meetups: User found - {user.Email}");
            Console.WriteLine("Meetups: Loading meetups from service...");

            meetups = await MeetupService.GetMyMeetupsAsync();
            
            if (meetups == null)
            {
                Console.WriteLine("Meetups: GetMyMeetupsAsync returned null");
                meetups = new List<MeetupDto>();
            }
            else
            {
                Console.WriteLine($"Meetups: Loaded {meetups.Count} meetups");
                meetups = meetups.OrderBy(m => m.EventDateTime).ToList();
            }

            var now = DateTime.Now;
            upcomingMeetups = meetups.Where(m => m.EventDateTime.ToLocalTime() > now).ToList();
            pastMeetups = meetups.Where(m => m.EventDateTime.ToLocalTime() <= now).ToList();

            Console.WriteLine($"Meetups: {upcomingMeetups.Count} upcoming, {pastMeetups.Count} past");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Meetups: Error loading - {ex.Message}");
            Console.WriteLine($"Meetups: Stack trace - {ex.StackTrace}");
            meetups = new List<MeetupDto>();
        }
        finally
        {
            loading = false;
            Console.WriteLine("Meetups: Loading complete");
        }
    }

    private void GoToCreateMeetup()
    {
        Console.WriteLine("Meetups: Navigating to create meetup");
        Nav.NavigateTo("/create-meetup");
    }

    private void SetFilter(string filter)
    {
        Console.WriteLine($"Meetups: Setting filter to {filter}");
        activeFilter = filter;
    }

    private List<MeetupDto> GetFilteredMeetups()
    {
        return activeFilter switch
        {
            "upcoming" => upcomingMeetups,
            "past" => pastMeetups,
            _ => meetups ?? new List<MeetupDto>()
        };
    }

    private bool IsPast(MeetupDto meetup)
    {
        return meetup.EventDateTime.ToLocalTime() < DateTime.Now;
    }

    private bool IsToday(MeetupDto meetup)
    {
        return meetup.EventDateTime.ToLocalTime().Date == DateTime.Today;
    }

    private bool IsSoon(MeetupDto meetup)
    {
        var daysUntil = (meetup.EventDateTime.ToLocalTime() - DateTime.Now).TotalDays;
        return daysUntil >= 0 && daysUntil <= 7;
    }

    private string GetCountdown(MeetupDto meetup)
    {
        var timeUntil = meetup.EventDateTime.ToLocalTime() - DateTime.Now;
        
        if (timeUntil.TotalDays >= 1)
            return $"in {(int)timeUntil.TotalDays} day{((int)timeUntil.TotalDays != 1 ? "s" : "")}";
        else if (timeUntil.TotalHours >= 1)
            return $"in {(int)timeUntil.TotalHours} hour{((int)timeUntil.TotalHours != 1 ? "s" : "")}";
        else
            return "starting soon";
    }

    private void ViewMeetupDetails(string meetupId)
    {
        Console.WriteLine($"Meetups: Navigating to meetup detail {meetupId}");
        Nav.NavigateTo($"/meetups/{meetupId}");
    }
}