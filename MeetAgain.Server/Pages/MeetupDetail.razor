@page "/meetups/{MeetupId}"
@inject MeetupService MeetupService
@inject FirestoreService FirestoreService
@inject AuthService Auth
@inject NavigationManager Nav

<div class="max-w-4xl mx-auto">
    @if (loading)
    {
        <div class="loading-container">
            <div class="loading-spinner"></div>
            <p style="margin-top: 1rem; color: var(--gray-600);">Loading meetup…</p>
        </div>
    }
    else if (meetup == null)
    {
        <div class="card">
            <div class="empty-state">
                <div class="empty-state-icon">❌</div>
                <h3 class="empty-state-title">Meetup Not Found</h3>
                <p class="empty-state-description">
                    This meetup doesn’t exist or you don’t have permission to view it.
                </p>
                <a href="/meetups" class="btn btn-primary">Back to Meetups</a>
            </div>
        </div>
    }
    else
    {
        <div class="card fade-in">
            <div class="meetup-header">
                <div class="meetup-header-content">
                    <a href="/meetups" class="btn-back">← Back to Meetups</a>
                    <h1 class="meetup-detail-title">@meetup.Title</h1>

                    <div class="meetup-meta">
                        <span class="meta-item">📅 @meetup.EventDateTime.ToLocalTime().ToString("MMMM dd, yyyy")</span>
                        <span class="meta-item">🕐 @meetup.EventDateTime.ToLocalTime().ToString("h:mm tt")</span>
                        <span class="meta-badge">
                            @if (IsPast())
                            {
                                <span class="badge badge-gray">Past Event</span>
                            }
                            else if (IsToday())
                            {
                                <span class="badge badge-warning">Today</span>
                            }
                            else if (IsSoon())
                            {
                                <span class="badge badge-primary">Coming Soon</span>
                            }
                            else
                            {
                                <span class="badge badge-success">Upcoming</span>
                            }
                        </span>
                    </div>
                </div>

                @if (!IsPast())
                {
                    <div class="meetup-actions">
                        <a href="/meetups/@MeetupId/edit" class="btn btn-secondary">✏️ Edit</a>

                        <a href="#"
                           @onclick="ShowDeleteModal"
                           @onclick:preventDefault
                           class="btn btn-outline"
                           style="color: var(--danger); border-color: var(--danger); text-decoration: none;">
                            🗑️ Delete
                        </a>
                    </div>
                }
            </div>
        </div>

        <div class="card fade-in">
            <h2 class="section-title">Description</h2>
            <p class="meetup-description">@meetup.Description</p>
        </div>

        @if (!IsPast())
        {
            <div class="card fade-in countdown-card">
                <div class="countdown-content">
                    <div class="countdown-icon">⏰</div>
                    <div>
                        <h3 class="countdown-title">Time Until Meetup</h3>
                        <p class="countdown-time">@GetCountdown()</p>
                    </div>
                </div>
            </div>
        }

        <div class="card fade-in">
            <h2 class="section-title">Event Information</h2>
            <div class="info-grid">
                <div class="info-item">
                    <span class="info-label">Created</span>
                    <span class="info-value">@meetup.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</span>
                </div>

                <div class="info-item">
                    <span class="info-label">Event ID</span>
                    <span class="info-value">@meetup.Id.Substring(0, 8)…</span>
                </div>

                <div class="info-item">
                    <span class="info-label">Status</span>
                    <span class="info-value">
                        @if (IsPast())
                        {
                            @:Completed
                        }
                        else
                        {
                            @:Scheduled
                        }
                    </span>
                </div>
            </div>
        </div>
    }
</div>

@if (showDeleteConfirm)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <h3 class="modal-title">Delete Meetup?</h3>

            <p class="modal-description">
                Are you sure you want to delete “<strong>@meetup?.Title</strong>”?
                This action cannot be undone.
            </p>

            <div class="modal-actions">
                <a href="#"
                   class="btn btn-outline"
                   @onclick="CancelDelete"
                   @onclick:preventDefault>
                    Cancel
                </a>

                <button type="button"
                        class="btn btn-primary"
                        style="background: var(--danger);"
                        disabled="@isDeleting"
                        @onclick="ConfirmDelete"
                        @onclick:preventDefault>
                    @if (isDeleting)
                    {
                        <span class="loading-spinner" style="width:1rem;height:1rem;margin-right:.5rem;"></span>
                        @:Deleting…
                    }
                    else
                    {
                        @:Delete Meetup
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string MeetupId { get; set; } = "";

    private Meetup? meetup;
    private bool loading = true;
    private bool showDeleteConfirm = false;
    private bool isDeleting = false;

    protected override async Task OnInitializedAsync()
    {
        var user = await Auth.GetCurrentUserAsync();
        if (user == null)
        {
            Nav.NavigateTo("/login");
            return;
        }

        try
        {
            meetup = await FirestoreService.GetMeetupByIdAsync(MeetupId);

            if (meetup != null && meetup.CreatorUserId != user.Uid)
                meetup = null;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"MeetupDetail: Error - {ex.Message}");
            meetup = null;
        }

        loading = false;
    }

    private bool IsPast() =>
        meetup?.EventDateTime.ToLocalTime() < DateTime.Now;

    private bool IsToday() =>
        meetup?.EventDateTime.ToLocalTime().Date == DateTime.Today;

    private bool IsSoon()
    {
        if (meetup == null) return false;
        var days = (meetup.EventDateTime.ToLocalTime() - DateTime.Now).TotalDays;
        return days >= 0 && days <= 7;
    }

    private string GetCountdown()
    {
        if (meetup == null) return "";
        var t = meetup.EventDateTime.ToLocalTime() - DateTime.Now;

        if (t.TotalDays >= 1) return $"{(int)t.TotalDays} days {t.Hours} hours";
        if (t.TotalHours >= 1) return $"{(int)t.TotalHours} hours {t.Minutes} minutes";
        if (t.TotalMinutes >= 1) return $"{(int)t.TotalMinutes} minutes";
        return "Starting soon!";
    }

    private void ShowDeleteModal() => showDeleteConfirm = true;

    private void CancelDelete() => showDeleteConfirm = false;

    private async Task ConfirmDelete()
    {
        if (meetup == null) return;

        isDeleting = true;
        var ok = await MeetupService.DeleteMeetupAsync(meetup.Id);

        if (ok)
        {
            Nav.NavigateTo("/meetups", true);
        }

        isDeleting = false;
    }
}
